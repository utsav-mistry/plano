# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=Plano

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=plano_super_secret_jwt_key_change_in_production_min32chars
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_SECRET=plano_refresh_secret_key_change_in_production

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/plano
MONGODB_POOL_SIZE=10

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=http

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Payment Gateways ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@plano.com
FROM_NAME=Plano

# ── Frontend URL (used in email templates) ────────────────────
FRONTEND_URL=http://localhost:3000

# ── PDF Generation ────────────────────────────────────────────
PDF_DIR=./storage/pdfs

# ── BullMQ ────────────────────────────────────────────────────
BULLMQ_CONCURRENCY=5

# ── Swagger ───────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_ROUTE=/api-docs
