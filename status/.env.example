# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Redis (same as backend) ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── BullMQ board login ────────────────────────────────────────────────────────
STATUS_USER=admin
STATUS_PASS=changeme_in_production

# ── Health Checkers ───────────────────────────────────────────────────────────
# true  → simulated checks, no real services needed (great for local dev)
# false → real checks against your actual services
MOCK_CHECKERS=true

BACKEND_HEALTH_URL=http://localhost:5000/health
FRONTEND_HEALTH_URL=http://localhost:3000
MONGO_URI=mongodb://localhost:27017/plano
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
